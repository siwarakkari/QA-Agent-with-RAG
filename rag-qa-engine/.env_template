

# ── Wikipedia Collector ──────────────────────────────────────────
WIKI_LANGUAGE=en
WIKI_USER_AGENT=RAG-WWII-Project/1.0

CORPUS_TARGET_ARTICLES=50
CORPUS_MIN_TEXT_LENGTH=1000
CORPUS_OUTPUT_DIR=wwii_corpus
CORPUS_OUTPUT_JSON=wwii_corpus.json
CORPUS_DELAY_MS=500
CORPUS_MAX_LINKS_PER_SEED=20
CORPUS_MAX_SEED_LINKS_FOLLOW=30
CORPUS_MAX_RESULTS_PER_SEARCH=20

# ── Chunking ─────────────────────────────────────────────────────
# Paragraphs with fewer words than this are kept as one unit
# Larger paragraphs are split into sentences
CHUNK_PARAGRAPH_THRESHOLD=80

# ── Embedding ────────────────────────────────────────────────────
# Options:
#   Xenova/all-MiniLM-L6-v2   (384-dim, fast, good quality)
#   Xenova/bge-small-en-v1.5  (384-dim, stronger retrieval)
#   Xenova/bge-base-en-v1.5   (768-dim, best quality, slower)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# ── Retrieval ────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RETRIEVAL_VECTOR_WEIGHT=0.7
RETRIEVAL_BM25_WEIGHT=0.3
QDRANT_URL=http://127.0.0.1:6333
QDRANT_DEFAULT_COLLECTION=wwii_corpus
set UNDICI_NO_KEEP_ALIVE=1
QDRANT_CONNECT_RETRIES=10    # try up to 10 times
QDRANT_CONNECT_DELAY_MS=2000 # wait 2s between attempts

SESSION_WINDOW_SIZE= 10

GROQ_API_KEY=
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_MAX_TOKENS=1024

EVAL_API_URL=http://localhost:3002/chat
EVAL_JUDGE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
EVAL_COLLECTION=wwii_corpus
EVAL_DELAY_MS=600